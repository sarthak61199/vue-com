generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id            String           @id @default(uuid())
  name          String
  price         Float
  description   String
  image         String?
  categoryId    String?
  category      Category?        @relation(fields: [categoryId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  variantTypes  VariantType[]
  variants      ProductVariant[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([categoryId])
  @@map("products")
}

model VariantType {
  id        String          @id @default(uuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  position  Int             @default(0)
  options   VariantOption[]

  @@index([productId])
  @@map("variant_types")
}

model VariantOption {
  id            String                @id @default(uuid())
  variantTypeId String
  variantType   VariantType           @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)
  value         String
  position      Int                   @default(0)
  variantValues ProductVariantValue[]

  @@index([variantTypeId])
  @@map("variant_options")
}

model ProductVariant {
  id         String                @id @default(uuid())
  productId  String
  product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  price      Float
  image      String?
  isDefault  Boolean               @default(false)
  createdAt  DateTime              @default(now())
  values     ProductVariantValue[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductVariantValue {
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionId  String
  option    VariantOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([variantId, optionId])
  @@map("product_variant_values")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  addresses     Address[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model Order {
  id         String      @id @default(uuid())
  total      Float
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  addressId  String?
  address    Address?    @relation(fields: [addressId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  order     Order          @relation(fields: [orderId], references: [id])
  orderId   String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId String
  quantity  Int
  price     Float

  @@id([orderId, variantId])
  @@index([orderId, variantId])
  @@map("order_items")
}

model Cart {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  cart      Cart           @relation(fields: [cartId], references: [id])
  cartId    String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId String
  quantity  Int

  @@id([cartId, variantId])
  @@index([cartId, variantId])
  @@map("cart_items")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@map("reviews")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  label     String?
  line1     String
  line2     String?
  city      String
  state     String
  zip       String
  country   String   @default("US")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  orders    Order[]

  @@index([userId])
  @@map("addresses")
}

model WishlistItem {
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@id([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}
